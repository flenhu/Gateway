# Server
PORT=8080
READ_TIMEOUT=30s
WRITE_TIMEOUT=30s

# Database
DATABASE_URL=postgres://gateway:gateway@localhost:5432/gateway?sslmode=disable

# Providers (add keys to enable)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Health Checker
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_FAILURE_THRESHOLD=3

# Logging
LOG_LEVEL=debug
LOG_FORMAT=console
